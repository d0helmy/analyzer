{
  "$schema": "appsettings-schema.json",
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Umbraco": "Information",
      "Analyzer": "Debug",
      "Customizer": "Debug"
    }
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "InstallMissingDatabase": true
      },
      "Hosting": {
        "Debug": true
      },
      "RuntimeMinification": {
        "UseInMemoryCache": true
      },
      "Unattended": {
        "InstallUnattended": true,
        "UnattendedUserName": "Local Dev",
        "UnattendedUserEmail": "dev@analyzer.local",
        "UnattendedUserPassword": "1234567890aA!"
      }
    }
  }
}
